{
  "name": "streamfence-js",
  "version": "1.1.0",
  "description": "Production-ready delivery control for Node.js Socket.IO servers - backpressure, retries, queue protection.",
  "license": "Apache-2.0",
  "author": "MoshPe",
  "homepage": "https://github.com/MoshPe/StreamFenceJs",
  "repository": {
    "type": "git",
    "url": "https://github.com/MoshPe/StreamFenceJs.git"
  },
  "keywords": [
    "socket.io",
    "websocket",
    "backpressure",
    "reliability",
    "streaming",
    "queue",
    "at-least-once",
    "delivery",
    "real-time"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "clean": "rimraf dist coverage",
    "examples:check": "tsc --noEmit --project tsconfig.examples.json",
    "test:package": "npm run build && node test/package/esm-consumer.mjs && node test/package/cjs-consumer.cjs"
  },
  "peerDependencies": {
    "prom-client": ">=14"
  },
  "peerDependenciesMeta": {
    "prom-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prom-client": "^15.1.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "prettier": "^3.2.5",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.2",
    "tsx": "^4.7.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "yaml": "^2.4.1"
  }
}
